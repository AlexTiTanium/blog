{
  "name": "blog",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@moku-labs/web": "1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "1.60.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "@vitest/coverage-istanbul": "4.0.18",
    "eslint": "9.39.3",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "62.6.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.1",
    "shiki": "3.22.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.0.18",
    "wrangler": "4.95.0"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun scripts/serve.ts",
    "preview": "bun scripts/preview.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:update:linux": "docker run --rm -v \"$PWD\":/w -w /w mcr.microsoft.com/playwright:v1.58.2-noble bunx playwright test --update-snapshots",
    "deploy": "bun scripts/deploy.ts",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write ."
  }
}
